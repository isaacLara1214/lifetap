{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "$session": {
        ".read": true,
        ".write": "newData.exists()",
        ".validate": "newData.hasChildren(['code', 'createdAt', 'updatedAt', 'status', 'creatorId', 'playerCount', 'players'])",
        "code": {
          ".validate": "newData.isString() && newData.val() === $session && newData.val().length === 6"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && (!data.exists() || newData.val() === data.val())"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'active' || newData.val() === 'closed')"
        },
        "creatorId": {
          ".validate": "newData.isString() && (!data.exists() || newData.val() === data.val())"
        },
        "playerCount": {
          ".validate": "newData.isNumber() && newData.val() >= 2 && newData.val() <= 10 && (!data.exists() || newData.val() === data.val())"
        },
        "players": {
          "$player": {
            ".validate": "newData.hasChildren(['id', 'name', 'life', 'color', 'commanderCount', 'commanders', 'joinedAt', 'lastSeenAt', 'isDead'])",
            "id": {
              ".validate": "newData.isString() && newData.val() === $player && (!data.exists() || newData.val() === data.val())"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "life": {
              ".validate": "newData.isNumber() && newData.val() >= -1000 && newData.val() <= 1000"
            },
            "color": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "commanderCount": {
              ".validate": "newData.isNumber() && (newData.val() === 1 || newData.val() === 2)"
            },
            "commanders": {
              "$index": {
                ".validate": "$index.matches(/^(0|1)$/) && newData.hasChildren(['id', 'name'])",
                "id": {
                  ".validate": "newData.isString() && newData.val().length > 0"
                },
                "name": {
                  ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
                },
                "$other": {
                  ".validate": false
                }
              }
            },
            "damageReceived": {
              "$index": {
                ".validate": "$index.matches(/^[0-9]+$/) && newData.hasChildren(['opponentId', 'opponentName', 'damageByCommander'])",
                "opponentId": {
                  ".validate": "newData.isString() && newData.val().length > 0"
                },
                "opponentName": {
                  ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
                },
                "damageByCommander": {
                  "$commanderId": {
                    ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
                  }
                },
                "$other": {
                  ".validate": false
                }
              }
            },
            "joinedAt": {
              ".validate": "newData.isNumber() && (!data.exists() || newData.val() === data.val())"
            },
            "lastSeenAt": {
              ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val())"
            },
            "isDead": {
              ".validate": "newData.isBoolean()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "locks": {
          "$cardId": {
            ".write": "newData.exists() || data.exists()",
            ".validate": "newData.hasChildren(['playerId', 'playerName', 'lockedAt'])",
            "playerId": {
              ".validate": "newData.isString() && newData.val().length > 0"
            },
            "playerName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "lockedAt": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
